# ==================== TELEGRAM ====================
# Токен бота (обязательно)
BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz

# ID администраторов (через запятую, без пробелов)
ADMIN_IDS=123456789,987654321

# ==================== DATABASE ====================
# Путь к файлу базы данных
DATABASE_PATH=/data/nexus.db

# ==================== GAMES ====================
# Минимальная ставка (NCoin)
MIN_BET=10

# Максимальная ставка (NCoin)
MAX_BET=10000

# Таймаут для принятия дуэли (секунды)
DUEL_TIMEOUT=60

# Лимит игр в минуту
RATE_LIMIT_GAMES=30

# ==================== MODERATION ====================
# Максимальное количество предупреждений до авто-бана
MAX_WARN_COUNT=3

# Максимальное количество сообщений для очистки
MAX_CLEAR_MESSAGES=100

# Максимальная длительность мута (дни)
MAX_MUTE_DAYS=30

# Задержка между командами (секунды)
RATE_LIMIT_SECONDS=3

# ==================== ENVIRONMENT ====================
# Окружение: development / production
BOT_ENV=production

# ==================== OZON BANK ====================
# Последние 4 цифры карты
OZON_CARD_LAST4=4436

# Название банка
OZON_BANK_NAME=Озон Банк

# Получатель платежа
OZON_RECEIVER=Александр Б.

# Ссылка на QR-код СБП
OZON_SBP_QR_URL=https://finance.ozon.ru/...

# ==================== AI (OpenRouter) ====================
# API ключ OpenRouter (опционально)
OPENROUTER_API_KEY=sk-or-v1-...

# ==================== PROMETHEUS (опционально) ====================
# Порт для метрик Prometheus
PROMETHEUS_PORT=9090

# Порт для health check
HEALTH_PORT=8080

# Токен для защиты /metrics эндпоинта
METRICS_TOKEN=your_secure_token_here

# ==================== REDIS (опционально) ====================
# URL для подключения к Redis
REDIS_URL=redis://localhost:6379

# Включить Redis
REDIS_ENABLED=false

# Требовать Redis в production
REQUIRE_REDIS_PRODUCTION=false

# ==================== SECURITY ====================
# Секретный ключ для подписей (сгенерируйте: openssl rand -hex 32)
SECRET_KEY=your_secret_key_here

# Время жизни подписи (секунды)
SIGNATURE_TTL=300

# Время жизни CSRF токена (секунды)
CSRF_TTL=600

# Алгоритм хеширования паролей
PASSWORD_HASH_ALGORITHM=pbkdf2-sha256

# Максимальная длина ввода (символы)
MAX_INPUT_LENGTH=4096

# ==================== LOGGING ====================
# Уровень логирования: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Путь к файлу логов
LOG_FILE=/data/nexus.log

# ==================== AUTO MODERATION ====================
# Включить автоматическую модерацию
AUTO_MODERATION_ENABLED=true

# Запрещённые паттерны (разделять |)
FORBIDDEN_PATTERNS=https?://|www\.|спам|реклама
